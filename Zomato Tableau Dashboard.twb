      <aliases enabled='yes' />
      <column caption='% Online Delivery' datatype='real' name='[%_Online_Delivery]' role='measure' type='quantitative' />
      <column caption='% Table Booking' datatype='real' name='[%_Table_Booking]' role='measure' type='quantitative' />
      <column caption='AVG Ratings' datatype='integer' name='[AVG_Ratings]' role='measure' type='quantitative' />
      <column caption='Average Cost for two' datatype='integer' name='[Average_Cost_for_two]' role='measure' type='quantitative' />
      <column caption='Financial Month' datatype='integer' name='[Calculation_1883912051571212288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Monthno] &gt;= 4 THEN [Monthno] - 3&#13;&#10;ELSE [Monthno] + 9&#13;&#10;END' />
      </column>
      <column caption='Total Cuisine ' datatype='integer' name='[Calculation_984318026714624000]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='countd([Cuisines])' />
      </column>
      <column caption='Total Cities' datatype='integer' name='[Calculation_984318026716053505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='countd([City])' />
      </column>
      <column caption='Total countires' datatype='integer' name='[Calculation_984318026716610562]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Country])' />
      </column>
      <column caption='Rating Bucket 1' datatype='string' name='[Calculation_984318026718633987]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Rating] &lt; 2 THEN &quot;Poor&quot;&#13;&#10;ELSEIF [Rating] &lt; 3 THEN &quot;Average&quot;&#13;&#10;ELSEIF [Rating] &lt; 4 THEN &quot;Good&quot;&#13;&#10;ELSE &quot;Excellent&quot;&#13;&#10;END' />
      </column>
      <column caption='Price Bucket 1 ' datatype='string' name='[Calculation_984318026718871556]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Average_Cost_for_two] &lt; 500 THEN &quot;&lt;500&quot;&#13;&#10;ELSEIF [Average_Cost_for_two] &lt; 1000 THEN &quot;500–999&quot;&#13;&#10;ELSEIF [Average_Cost_for_two] &lt; 2000 THEN &quot;1000–1999&quot;&#13;&#10;ELSE &quot;2000+&quot;&#13;&#10;END' />
      </column>
      <column caption='% With Table Booking 1' datatype='real' name='[Calculation_984318026718978053]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Has_Table_booking]=&quot;Yes&quot; THEN 1 ELSE 0 END) / COUNT([RestaurantID])' />
      </column>
      <column caption='% With Online Delivery 1 ' datatype='real' name='[Calculation_984318026719121414]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Has_Online_delivery]=&quot;Yes&quot; THEN 1 ELSE 0 END) / COUNT([RestaurantID])' />
      </column>
      <column caption='% Currently Delivering Now 1 ' datatype='real' name='[Calculation_984318026719227911]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Is_delivering_now]=&quot;Yes&quot; THEN 1 ELSE 0 END) / COUNT([RestaurantID])' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
